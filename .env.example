# ===========================================
# Supabase
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# EMQX Cloud
# ===========================================
EMQX_BROKER_URL=your-broker.emqxsl.com
EMQX_BROKER_PORT=8883
EMQX_HTTP_API_URL=https://your-broker.emqxsl.com:8443
EMQX_HTTP_API_KEY=your-api-key
EMQX_HTTP_API_SECRET=your-api-secret

# ===========================================
# MQTT Credentials (Edge Gateway)
# ===========================================
MQTT_USERNAME=xrf-dev-001
MQTT_PASSWORD=your-mqtt-password

# ===========================================
# MQTT Credentials (Ingestion Service)
# ===========================================
INGESTION_MQTT_USERNAME=ingestion-svc
INGESTION_MQTT_PASSWORD=your-ingestion-mqtt-password

# ===========================================
# Local Database (Edge Gateway only)
# ===========================================
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=xrfonstream
LOCAL_DB_USER=sax
LOCAL_DB_PASSWORD=your-local-db-password

# ===========================================
# Security
# ===========================================
HMAC_SECRET=your-256-bit-hmac-secret

# ===========================================
# Device Identity
# ===========================================
DEVICE_ID=your-device-uuid
TENANT_ID=your-tenant-uuid
